<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HTML → GitHub Pages 發布工具</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Noto+Sans+TC:wght@300;400;500;700&display=swap');

  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface2: #1a1a26;
    --border: #2a2a3d;
    --accent: #6c63ff;
    --accent2: #00d4aa;
    --accent3: #ff6b6b;
    --text: #e8e8f0;
    --muted: #8888aa;
    --success: #00d4aa;
    --error: #ff6b6b;
    --warning: #ffcc44;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans TC', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(108,99,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(108,99,255,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 24px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  header {
    text-align: center;
    margin-bottom: 52px;
  }

  .logo-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 18px;
    font-weight: 700;
  }

  h1 {
    font-family: 'Space Mono', monospace;
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 700;
    letter-spacing: -0.5px;
    background: linear-gradient(90deg, #fff 30%, var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: var(--muted);
    font-size: 15px;
    margin-top: 8px;
  }

  /* Steps indicator */
  .steps {
    display: flex;
    gap: 0;
    margin-bottom: 36px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .step {
    flex: 1;
    padding: 14px 16px;
    text-align: center;
    font-size: 13px;
    color: var(--muted);
    background: var(--surface);
    cursor: pointer;
    transition: all 0.2s;
    border-right: 1px solid var(--border);
    position: relative;
  }
  .step:last-child { border-right: none; }
  .step.active {
    background: var(--surface2);
    color: var(--text);
  }
  .step.done { color: var(--accent2); }
  .step .step-num {
    display: inline-flex;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--border);
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    margin-right: 6px;
    vertical-align: middle;
  }
  .step.active .step-num { background: var(--accent); color: #fff; }
  .step.done .step-num { background: var(--accent2); color: #000; }

  /* Cards */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 20px;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: #3a3a5d; }
  .card-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .card-title .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* Token input */
  .input-group { margin-bottom: 16px; }
  .input-group label {
    display: block;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .input-row {
    display: flex;
    gap: 10px;
  }
  input[type="text"], input[type="password"] {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--text);
    font-size: 14px;
    font-family: 'Space Mono', monospace;
    outline: none;
    transition: border-color 0.2s;
  }
  input:focus { border-color: var(--accent); }

  .btn {
    padding: 10px 20px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .btn:active { transform: scale(0.97); }
  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover { background: #7d75ff; }
  .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { background: var(--surface2); }
  .btn-success {
    background: var(--accent2);
    color: #000;
    font-weight: 700;
  }
  .btn-success:hover { background: #00e8bb; }
  .btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none !important;
  }

  /* File upload zone */
  .upload-zone {
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 48px 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }
  .upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--accent);
    background: rgba(108,99,255,0.05);
  }
  .upload-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .upload-icon {
    font-size: 40px;
    margin-bottom: 12px;
  }
  .upload-zone p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
  }
  .upload-zone strong { color: var(--text); }

  /* File list */
  .file-list { margin-top: 16px; }
  .file-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--surface2);
    border-radius: 8px;
    margin-bottom: 8px;
    font-size: 13px;
  }
  .file-item .file-name {
    flex: 1;
    font-family: 'Space Mono', monospace;
    color: var(--accent2);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .file-item .file-size { color: var(--muted); }
  .file-remove {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    padding: 2px 4px;
  }
  .file-remove:hover { color: var(--error); }

  /* Repo settings */
  .settings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 560px) { .settings-grid { grid-template-columns: 1fr; } }

  /* Log / status */
  .log-box {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    line-height: 1.8;
    max-height: 220px;
    overflow-y: auto;
    margin-top: 16px;
  }
  .log-entry { display: flex; gap: 8px; }
  .log-time { color: var(--muted); flex-shrink: 0; }
  .log-msg.info { color: var(--text); }
  .log-msg.success { color: var(--accent2); }
  .log-msg.error { color: var(--error); }
  .log-msg.warn { color: var(--warning); }

  /* Result panel */
  .result-panel {
    background: linear-gradient(135deg, rgba(0,212,170,0.08), rgba(108,99,255,0.08));
    border: 1px solid var(--accent2);
    border-radius: 16px;
    padding: 28px;
    margin-top: 20px;
    display: none;
  }
  .result-panel.show { display: block; }
  .result-url {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    color: var(--accent2);
    word-break: break-all;
    background: var(--bg);
    border-radius: 8px;
    padding: 12px 14px;
    margin: 12px 0;
  }
  .result-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }

  /* Progress bar */
  .progress-wrap {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 16px;
  }
  .progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 2px;
    width: 0%;
    transition: width 0.3s;
  }

  /* Status badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
  }
  .badge-ok { background: rgba(0,212,170,0.12); color: var(--accent2); }
  .badge-err { background: rgba(255,107,107,0.12); color: var(--error); }
  .badge-pending { background: rgba(108,99,255,0.12); color: var(--accent); }

  /* Token note */
  .note {
    background: rgba(255,204,68,0.08);
    border: 1px solid rgba(255,204,68,0.25);
    border-radius: 8px;
    padding: 12px 14px;
    font-size: 13px;
    color: var(--warning);
    margin-top: 12px;
    line-height: 1.6;
  }
  .note a { color: var(--accent); }

  /* Tip */
  .tip {
    font-size: 13px;
    color: var(--muted);
    margin-top: 8px;
    line-height: 1.6;
  }

  .section-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 28px 0;
    color: var(--muted);
    font-size: 12px;
  }
  .section-divider::before, .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .spin {
    display: inline-block;
    animation: spin 0.8s linear infinite;
    margin-right: 6px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .action-row {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 20px;
  }

  /* Preview iframe area */
  .preview-label {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 6px;
    font-family: 'Space Mono', monospace;
  }
  .preview-frame-wrap {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-top: 8px;
  }
  .preview-bar {
    background: var(--surface2);
    padding: 8px 12px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
  }
  iframe {
    width: 100%;
    height: 280px;
    border: none;
    background: #fff;
    display: block;
  }
</style>
</head>
<body>
<div class="container">

  <header>
    <div class="logo-row">
      <div class="logo-icon">⌬</div>
      <h1>HTML → GitHub Pages</h1>
    </div>
    <p class="subtitle">上傳 HTML 檔案，一鍵發布為公開網站</p>
  </header>

  <!-- Steps -->
  <div class="steps">
    <div class="step active" id="step1-tab">
      <span class="step-num">1</span>Token 設定
    </div>
    <div class="step" id="step2-tab">
      <span class="step-num">2</span>上傳檔案
    </div>
    <div class="step" id="step3-tab">
      <span class="step-num">3</span>發布設定
    </div>
    <div class="step" id="step4-tab">
      <span class="step-num">4</span>發布！
    </div>
  </div>

  <!-- Step 1: Token -->
  <div id="panel-step1">
    <div class="card">
      <div class="card-title"><span class="dot"></span>GitHub Personal Access Token</div>
      <div class="input-group">
        <label>Token（不會儲存，僅用於此次發布）</label>
        <div class="input-row">
          <input type="password" id="token-input" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" autocomplete="off" />
          <button class="btn btn-ghost" id="toggle-token">顯示</button>
          <button class="btn btn-primary" id="verify-token">驗證</button>
        </div>
      </div>
      <div class="note">
        ⚠️ 需要 <strong>classic token</strong>，請至 <a href="https://github.com/settings/tokens/new" target="_blank">GitHub Settings → Developer settings → Personal access tokens</a>
        建立，勾選 <code>repo</code> 權限（含 public_repo）。Token 僅在此瀏覽器記憶體使用，不會傳送至任何第三方。
      </div>
      <div id="token-status" style="margin-top:12px;"></div>
    </div>
    <div class="action-row">
      <button class="btn btn-primary" id="next1" disabled>下一步 →</button>
    </div>
  </div>

  <!-- Step 2: Upload -->
  <div id="panel-step2" style="display:none;">
    <div class="card">
      <div class="card-title"><span class="dot"></span>上傳 HTML 檔案</div>
      <div class="upload-zone" id="upload-zone">
        <input type="file" id="file-input" accept=".html,.htm,.css,.js,.png,.jpg,.jpeg,.gif,.svg,.ico,.webp" multiple />
        <div class="upload-icon">⬆</div>
        <p><strong>拖曳檔案至此</strong>或點擊選取</p>
        <p style="margin-top:6px;">支援 HTML、CSS、JS、圖片等靜態資源</p>
      </div>
      <div class="file-list" id="file-list"></div>
    </div>

    <!-- Preview -->
    <div class="card" id="preview-card" style="display:none;">
      <div class="card-title"><span class="dot" style="background:var(--accent2)"></span>預覽</div>
      <div class="preview-bar" id="preview-bar">preview</div>
      <div class="preview-frame-wrap">
        <iframe id="preview-frame"></iframe>
      </div>
    </div>

    <div class="action-row">
      <button class="btn btn-ghost" onclick="showStep(1)">← 上一步</button>
      <button class="btn btn-primary" id="next2" disabled>下一步 →</button>
    </div>
  </div>

  <!-- Step 3: Settings -->
  <div id="panel-step3" style="display:none;">
    <div class="card">
      <div class="card-title"><span class="dot"></span>發布設定</div>
      <div class="settings-grid">
        <div class="input-group">
          <label>GitHub 帳號</label>
          <input type="text" id="gh-user" placeholder="your-username" readonly style="opacity:0.7;" />
        </div>
        <div class="input-group">
          <label>Repository 名稱</label>
          <input type="text" id="repo-name" placeholder="my-website" />
        </div>
      </div>
      <div class="input-group" style="margin-top:4px;">
        <label>網站描述（選填）</label>
        <input type="text" id="repo-desc" placeholder="My awesome website" />
      </div>
      <div class="tip">
        ℹ️ 若 Repo 已存在則會更新其內容；若不存在則自動建立。
        發布後網址為：<code id="preview-url" style="color:var(--accent2);">https://你的帳號.github.io/repo名稱</code>
      </div>
    </div>
    <div class="action-row">
      <button class="btn btn-ghost" onclick="showStep(2)">← 上一步</button>
      <button class="btn btn-primary" id="next3">下一步 →</button>
    </div>
  </div>

  <!-- Step 4: Deploy -->
  <div id="panel-step4" style="display:none;">
    <div class="card">
      <div class="card-title"><span class="dot"></span>發布進度</div>
      <div id="deploy-summary" style="font-size:14px;color:var(--muted);margin-bottom:16px;"></div>
      <div class="progress-wrap">
        <div class="progress-bar" id="progress-bar"></div>
      </div>
      <div class="log-box" id="log-box"></div>
    </div>

    <!-- Result -->
    <div class="result-panel" id="result-panel">
      <div style="font-size:18px;font-weight:700;color:var(--accent2);">🎉 發布成功！</div>
      <p style="color:var(--muted);font-size:13px;margin-top:6px;">你的網站已上傳至 GitHub Pages，稍等幾分鐘後即可訪問：</p>
      <div class="result-url" id="result-url"></div>
      <div class="result-actions">
        <button class="btn btn-success" id="open-site">開啟網站 ↗</button>
        <button class="btn btn-ghost" id="open-repo">查看 Repo ↗</button>
        <button class="btn btn-ghost" onclick="showStep(1);resetAll()">再次發布</button>
      </div>
      <p style="font-size:12px;color:var(--muted);margin-top:12px;">⏱ GitHub Pages 首次啟用可能需要 1～3 分鐘</p>
    </div>

    <div class="action-row" style="margin-top:12px;">
      <button class="btn btn-ghost" id="back4" onclick="showStep(3)">← 返回</button>
      <button class="btn btn-success" id="deploy-btn">
        🚀 開始發布
      </button>
    </div>
  </div>

</div>

<script>
const GITHUB_API = 'https://api.github.com';
let state = {
  token: '',
  username: '',
  files: [],
  repoName: '',
  repoDesc: '',
};

// ── Step navigation ──
function showStep(n) {
  [1,2,3,4].forEach(i => {
    document.getElementById('panel-step' + i).style.display = i === n ? '' : 'none';
    const tab = document.getElementById('step' + i + '-tab');
    tab.classList.toggle('active', i === n);
  });
}

// ── Step 1: Token ──
document.getElementById('toggle-token').onclick = function() {
  const inp = document.getElementById('token-input');
  const show = inp.type === 'password';
  inp.type = show ? 'text' : 'password';
  this.textContent = show ? '隱藏' : '顯示';
};

document.getElementById('verify-token').onclick = async function() {
  const token = document.getElementById('token-input').value.trim();
  if (!token) return;
  this.disabled = true;
  this.textContent = '驗證中…';
  const el = document.getElementById('token-status');
  try {
    const res = await fetch(`${GITHUB_API}/user`, {
      headers: { Authorization: `token ${token}`, Accept: 'application/vnd.github+json' }
    });
    const data = await res.json();
    if (res.ok) {
      state.token = token;
      state.username = data.login;
      el.innerHTML = `<span class="badge badge-ok">✓ 已驗證：${data.login}（${data.name || ''}）</span>`;
      document.getElementById('next1').disabled = false;
      document.getElementById('gh-user').value = data.login;
    } else {
      el.innerHTML = `<span class="badge badge-err">✗ 驗證失敗：${data.message}</span>`;
    }
  } catch(e) {
    el.innerHTML = `<span class="badge badge-err">✗ 網路錯誤：${e.message}</span>`;
  }
  this.disabled = false;
  this.textContent = '驗證';
};

document.getElementById('next1').onclick = () => showStep(2);

// ── Step 2: Upload ──
const fileInput = document.getElementById('file-input');
const uploadZone = document.getElementById('upload-zone');

uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault();
  uploadZone.classList.remove('drag-over');
  addFiles([...e.dataTransfer.files]);
});
fileInput.addEventListener('change', () => addFiles([...fileInput.files]));

function addFiles(newFiles) {
  newFiles.forEach(f => {
    if (!state.files.find(x => x.name === f.name)) state.files.push(f);
  });
  renderFileList();
  updatePreview();
}

function renderFileList() {
  const el = document.getElementById('file-list');
  el.innerHTML = '';
  state.files.forEach((f, i) => {
    const div = document.createElement('div');
    div.className = 'file-item';
    div.innerHTML = `
      <span class="file-name">📄 ${f.name}</span>
      <span class="file-size">${formatSize(f.size)}</span>
      <button class="file-remove" data-i="${i}" title="移除">✕</button>
    `;
    el.appendChild(div);
  });
  el.querySelectorAll('.file-remove').forEach(btn => {
    btn.onclick = () => { state.files.splice(+btn.dataset.i, 1); renderFileList(); updatePreview(); };
  });
  document.getElementById('next2').disabled = state.files.length === 0;
}

function formatSize(bytes) {
  if (bytes < 1024) return bytes + 'B';
  if (bytes < 1048576) return (bytes/1024).toFixed(1) + 'KB';
  return (bytes/1048576).toFixed(1) + 'MB';
}

function updatePreview() {
  const htmlFile = state.files.find(f => f.name.endsWith('.html') || f.name.endsWith('.htm'));
  const card = document.getElementById('preview-card');
  if (!htmlFile) { card.style.display = 'none'; return; }
  card.style.display = '';
  document.getElementById('preview-bar').textContent = htmlFile.name;
  const reader = new FileReader();
  reader.onload = e => {
    const frame = document.getElementById('preview-frame');
    frame.srcdoc = e.target.result;
  };
  reader.readAsText(htmlFile);
}

document.getElementById('next2').onclick = () => showStep(3);

// ── Step 3: Settings ──
document.getElementById('repo-name').addEventListener('input', updatePreviewUrl);
function updatePreviewUrl() {
  const repo = document.getElementById('repo-name').value.trim() || 'repo名稱';
  const user = state.username || '你的帳號';
  document.getElementById('preview-url').textContent = `https://${user}.github.io/${repo}`;
}

document.getElementById('next3').onclick = () => {
  state.repoName = document.getElementById('repo-name').value.trim();
  state.repoDesc = document.getElementById('repo-desc').value.trim();
  if (!state.repoName) { alert('請輸入 Repository 名稱'); return; }
  document.getElementById('deploy-summary').textContent =
    `準備發布 ${state.files.length} 個檔案 → ${state.username}/${state.repoName}`;
  showStep(4);
};

// ── Step 4: Deploy ──
function log(msg, type = 'info') {
  const box = document.getElementById('log-box');
  const now = new Date().toLocaleTimeString('zh-TW', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const div = document.createElement('div');
  div.className = 'log-entry';
  div.innerHTML = `<span class="log-time">${now}</span><span class="log-msg ${type}">${msg}</span>`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

function setProgress(pct) {
  document.getElementById('progress-bar').style.width = pct + '%';
}

async function ghAPI(path, method = 'GET', body = null) {
  const opts = {
    method,
    headers: {
      Authorization: `token ${state.token}`,
      Accept: 'application/vnd.github+json',
      'Content-Type': 'application/json',
    }
  };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(GITHUB_API + path, opts);
  const data = await res.json();
  return { ok: res.ok, status: res.status, data };
}

async function fileToBase64(file) {
  return new Promise((res, rej) => {
    const r = new FileReader();
    r.onload = e => res(e.target.result.split(',')[1]);
    r.onerror = rej;
    r.readAsDataURL(file);
  });
}

document.getElementById('deploy-btn').onclick = async function() {
  const btn = this;
  btn.disabled = true;
  document.getElementById('back4').disabled = true;
  document.getElementById('result-panel').classList.remove('show');
  document.getElementById('log-box').innerHTML = '';
  setProgress(0);

  const { token, username, repoName, repoDesc, files } = state;
  const htmlFile = files.find(f => /\.html?$/.test(f.name));
  if (!htmlFile) { log('找不到 HTML 主檔案', 'error'); btn.disabled = false; document.getElementById('back4').disabled = false; return; }

  try {
    // 1. Check / create repo
    log(`檢查 Repo：${username}/${repoName}…`);
    let { ok, status, data: repoData } = await ghAPI(`/repos/${username}/${repoName}`);

    if (status === 404) {
      log('Repo 不存在，正在建立…', 'warn');
      const created = await ghAPI('/user/repos', 'POST', {
        name: repoName,
        description: repoDesc || 'Published via HTML→GitHub Pages',
        private: false,
        auto_init: true,
      });
      if (!created.ok) throw new Error('建立 Repo 失敗：' + (created.data.message || ''));
      log('Repo 建立成功 ✓', 'success');
      await new Promise(r => setTimeout(r, 1500));
    } else if (!ok) {
      throw new Error('無法存取 Repo：' + (repoData.message || ''));
    } else {
      log('Repo 已存在，將更新檔案 ✓', 'success');
    }

    setProgress(15);

    // 2. Ensure gh-pages branch
    log('檢查 gh-pages branch…');
    const { ok: brOk, data: brData } = await ghAPI(`/repos/${username}/${repoName}/branches/gh-pages`);
    let baseSha = null;

    if (!brOk) {
      log('建立 gh-pages branch…');
      const { data: mainBr } = await ghAPI(`/repos/${username}/${repoName}/branches/main`);
      const mainSha = mainBr?.commit?.sha;
      if (!mainSha) {
        // try master
        const { data: masterBr } = await ghAPI(`/repos/${username}/${repoName}/branches/master`);
        baseSha = masterBr?.commit?.sha;
      } else {
        baseSha = mainSha;
      }
      if (!baseSha) throw new Error('找不到預設 branch 的 SHA');
      const { ok: cOk, data: cData } = await ghAPI(`/repos/${username}/${repoName}/git/refs`, 'POST', {
        ref: 'refs/heads/gh-pages',
        sha: baseSha,
      });
      if (!cOk) throw new Error('建立 gh-pages 失敗：' + (cData.message || ''));
      log('gh-pages branch 建立成功 ✓', 'success');
    } else {
      log('gh-pages branch 已存在 ✓', 'success');
    }

    setProgress(25);

    // 3. Upload files
    const total = files.length;
    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      log(`上傳 ${file.name} (${formatSize(file.size)})…`);
      const content = await fileToBase64(file);

      // Check if file exists to get SHA for update
      const { ok: existOk, data: existData } = await ghAPI(
        `/repos/${username}/${repoName}/contents/${encodeURIComponent(file.name)}?ref=gh-pages`
      );
      const fileSha = existOk ? existData.sha : undefined;

      const { ok: uploadOk, data: uploadData } = await ghAPI(
        `/repos/${username}/${repoName}/contents/${encodeURIComponent(file.name)}`,
        'PUT',
        {
          message: `Upload ${file.name} via HTML→GitHub Pages tool`,
          content,
          branch: 'gh-pages',
          ...(fileSha ? { sha: fileSha } : {}),
        }
      );
      if (!uploadOk) throw new Error(`上傳 ${file.name} 失敗：${uploadData.message || ''}`);
      log(`${file.name} 上傳完成 ✓`, 'success');
      setProgress(25 + Math.round(60 * (i + 1) / total));
    }

    // 4. Enable GitHub Pages
    log('啟用 GitHub Pages…');
    const { ok: pgOk, data: pgData } = await ghAPI(`/repos/${username}/${repoName}/pages`, 'POST', {
      source: { branch: 'gh-pages', path: '/' }
    });
    if (!pgOk && pgData.message && !pgData.message.includes('already enabled')) {
      log(`Pages 設定：${pgData.message}`, 'warn');
    } else {
      log('GitHub Pages 啟用 ✓', 'success');
    }

    setProgress(100);

    const siteUrl = `https://${username}.github.io/${repoName}`;
    const repoUrl = `https://github.com/${username}/${repoName}`;

    document.getElementById('result-url').textContent = siteUrl;
    document.getElementById('open-site').onclick = () => window.open(siteUrl, '_blank');
    document.getElementById('open-repo').onclick = () => window.open(repoUrl, '_blank');
    document.getElementById('result-panel').classList.add('show');
    log('🎉 全部完成！', 'success');

  } catch(e) {
    log('❌ 發布失敗：' + e.message, 'error');
    setProgress(0);
    btn.disabled = false;
    document.getElementById('back4').disabled = false;
  }
};

function resetAll() {
  state = { token: state.token, username: state.username, files: [], repoName: '', repoDesc: '' };
  document.getElementById('file-list').innerHTML = '';
  document.getElementById('log-box').innerHTML = '';
  document.getElementById('progress-bar').style.width = '0';
  document.getElementById('result-panel').classList.remove('show');
  document.getElementById('next2').disabled = true;
  document.getElementById('preview-card').style.display = 'none';
  document.getElementById('repo-name').value = '';
  document.getElementById('repo-desc').value = '';
}

// Update preview URL on load
document.getElementById('repo-name').addEventListener('input', updatePreviewUrl);
</script>
